/* pages/index/index.wxss */
page {
  background-color: #f4f6f9;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', sans-serif;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 顶部文案区 */
.header {
  margin-top: 20rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 52rpx; /* 大字体 */
  font-weight: 900;
  color: #1e293b;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 30rpx;
  color: #64748b;
  font-weight: 500;
}

/* 组合按钮 */
.action-buttons {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 50rpx;
}

.upload-btn {
  width: 90% !important;
  border-radius: 80rpx;
  /* 强制超级大字：44rpx */
  font-size: 44rpx !important; 
  font-weight: 900 !important;
  padding: 20rpx 0;
  box-shadow: 0 10rpx 20rpx -5rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: white;
}

.secondary {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
}

/* 瀑布流结果卡片 */
.result-card {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 15rpx 35rpx -5rpx rgba(0,0,0,0.1);
  overflow: hidden;
  box-sizing: border-box;
  animation: slideUp 0.4s ease;
  margin-bottom: 60rpx;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.card-header {
  padding: 24rpx 30rpx;
  background-color: #f8fafc;
  border-bottom: 1px solid #f1f5f9;
  display: flex;
  align-items: center;
}

.success-dot {
  width: 18rpx; height: 18rpx;
  background-color: #10b981;
  border-radius: 50%;
  margin-right: 15rpx;
}

.error-dot {
  width: 18rpx; height: 18rpx;
  background-color: #ef4444;
  border-radius: 50%;
  margin-right: 15rpx;
}

.card-title {
  font-size: 32rpx; /* 栏目标题大字 */
  color: #334155;
  font-weight: 900;
}

.image-wrapper {
  position: relative;
  width: 100%;
  height: 480rpx;
  background-color: #0f172a;
}

.preview-img {
  width: 100%; height: 100%;
  opacity: 0.95;
}

.image-overlay {
  position: absolute;
  bottom: 20rpx; right: 20rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fbbf24;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 10rpx;
}

/* 警告框 */
.mode-banner {
  background-color: #fef2f2;
  border-left: 8rpx solid #ef4444;
  padding: 24rpx 30rpx;
}
.warning-text {
  font-size: 34rpx;
  color: #b91c1c;
  font-weight: bold;
}

/* 处方笺区 */
.analysis-panel {
  padding: 30rpx;
  background-color: #ffffff;
}

.section-title {
  display: block;
  font-size: 38rpx; /* 大图标题 */
  font-weight: 900;
  color: #1e293b;
  margin-bottom: 30rpx;
  border-left: 10rpx solid #3b82f6;
  padding-left: 20rpx;
}

.advice-content {
  background-color: #f0fdf4;
  border: 1px solid #bbf7d0;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.candidate-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.candidate-name {
  font-size: 38rpx; /* 更大的标题 */
  color: #166534;
  font-weight: 900;
}

.conf-badge {
  font-size: 30rpx;
  color: #10b981;
  font-weight: bold;
}

.orange-text {
  font-size: 32rpx;
  color: #d97706;
  font-weight: bold;
}

.candidate-desc {
  display: block;
  font-size: 34rpx; /* 大字描述 */
  color: #15803d;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

.candidate-advice {
  display: block;
  font-size: 34rpx; /* 大字建议 */
  color: #0d9488;
  font-weight: bold;
  line-height: 1.6;
}

/* 合规免责区 (极其显眼) */
.disclaimer-area {
  padding: 40rpx 30rpx;
  background-color: #fff1f2;
  border-top: 4rpx solid #fecdd3;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.disclaimer-title {
  font-size: 40rpx; /* 大字预警 */
  font-weight: 900;
  color: #e11d48;
  margin-bottom: 15rpx;
}

.disclaimer-text {
  font-size: 32rpx; /* 内容字号也放大 */
  color: #be123c;
  line-height: 1.6;
  font-weight: bold;
  text-align: center;
}